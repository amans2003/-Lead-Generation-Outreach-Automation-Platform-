# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/leadgen

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=7d

# ─── Anthropic / Claude AI ────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Twilio (SMS) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ─── Email ────────────────────────────────────────────────
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token_here

# ─── WhatsApp ─────────────────────────────────────────────
WHATSAPP_SESSION_PATH=./whatsapp-sessions
WHATSAPP_HEADLESS=true

# ─── Scraper ──────────────────────────────────────────────
SCRAPER_DAILY_TARGET=500
SCRAPER_BATCH_SIZE=50
SCRAPER_DELAY_MIN_MS=2000
SCRAPER_DELAY_MAX_MS=5000
SCRAPER_CONCURRENT_TABS=3
SCRAPER_HEADLESS=true
SCRAPER_SCHEDULE_CRON=0 2 * * *
PROXY_LIST=
SCRAPER_TARGET_CITIES=Mumbai,Delhi,Bangalore,Hyderabad,Chennai,Pune

# ─── Bloom Filter ─────────────────────────────────────────
BLOOM_FILTER_CAPACITY=1000000
BLOOM_FILTER_ERROR_RATE=0.01

# ─── Outreach Rate Limits ─────────────────────────────────
OUTREACH_SMS_PER_HOUR=50
OUTREACH_EMAIL_PER_HOUR=100
OUTREACH_WHATSAPP_PER_HOUR=30
OUTREACH_DELAY_BETWEEN_MS=3000

# ─── Lead Scoring ─────────────────────────────────────────
LEAD_SCORE_GOOD_THRESHOLD=70
LEAD_SCORE_SKIP_THRESHOLD=30

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs
